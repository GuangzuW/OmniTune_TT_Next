FROM golang:1.21-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .
# Output to /out to avoid colliding with the ./user_sync source directory.
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/user_sync ./user_sync

FROM alpine:latest
WORKDIR /root/
COPY --from=builder /out/user_sync .
EXPOSE 8001
CMD ["./user_sync"]
